          "complex": {
            "root": "severity_score",
            "filters": [],
            "transformers": [{"operator": "MapRangeValues", "args": {
              "map_from": {"value": {"simple": "0-49,50-79,80-100"}, "isContext": false},
              "map_to":   {"value": {"simple": "low,medium,high"},   "isContext": false},
              "sep":      {"isContext": false}
