{
  "id": "Bitdefender GravityZone - Incoming Mapper",
  "name": "Bitdefender GravityZone - Incoming Mapper",
  "description": "Maps Bitdefender GravityZone push event fields to XSOAR incident fields.",
  "type": "mapping-incoming",
  "version": -1,
  "fromVersion": "6.0.0",
  "mapping": {
    "Bitdefender GravityZone Malware": {
      "dontMapEventToLabels": true,
      "internalMapping": {
        "name":                             {"simple": "malware_name"},
        "occurred":                         {"simple": "timestamp"},
        "severity": {
          "complex": {
            "root": "detection_level",
            "filters": [],
            "transformers": [{"operator": "MapValuesToTable", "args": {
              "table": {"value": {"simple": "Aggressive:3,Normal:2,Permissive:1"}, "isContext": false}
            }}]
          }
        },
        "GravityZone Module":               {"simple": "module"},
        "GravityZone Company ID":           {"simple": "companyId"},
        "GravityZone Computer ID":          {"simple": "computer_id"},
        "GravityZone Computer Name":        {"simple": "computer_name"},
        "GravityZone Computer FQDN":        {"simple": "computer_fqdn"},
        "GravityZone Computer IP":          {"simple": "computer_ip"},
        "GravityZone Product Installed":    {"simple": "product_installed"},
        "GravityZone Malware Name":         {"simple": "malware_name"},
        "GravityZone File Path":            {"simple": "file_path"},
        "GravityZone SHA256":               {"simple": "hash"},
        "GravityZone Detection Level":      {"simple": "detection_level"},
        "GravityZone Infection Status":     {"simple": "final_status"},
        "GravityZone Attack Types":         {"simple": "attack_types"}
      }
    },
    "Bitdefender GravityZone Exchange Malware": {
      "dontMapEventToLabels": true,
